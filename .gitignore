.env
.DS_Store

# BotLearn SDK 本地状态 —— 含 api_key,绝对不能入库
.botlearn/

# BotLearn SDK 第三方源码 —— 见 docs/06-installation.md §10 自行安装,不入本仓
skills/botlearn/

# 本机 Claude Code 配置(allowlist / scheduled tasks / settings.local.json)—— 不入库
.claude/

# 本机安装的其他 skill 副本 —— 不属于 mba 项目本身,不入库
skills/

# 跑过的审计报告默认不入库 —— 报告归用户所有,可能含敏感品牌信息
# 如需分享某份特定报告,先人工 review,再复制到 published/reports/<brand>/ 并显式 add
# 注:无 trailing slash,这样既匹配目录,也匹配 symlink(2026-06 reports/ 被 symlink 到 private/reports)
metric-brand-auditor/reports
metric-brand-auditor/.reports.backup-*

# 脱敏报告目录 —— private/ 与 published/ 形成"私 vs 公"对仗:
# private/   = 仅本地审阅,严格禁止 GitHub / 外网 / Cloudflare Pages / 任何第三方
# published/ = 经人工 review 后对外发布的报告(默认仍 ignored,需显式 git add)
# 任何放进 private/ 的内容都不会进入 git,也不会经过 build 脚本 deploy
private/

# Cloudflare Pages 本地 build 产物(CF Pages 自己会 build,不入库)
site/reports/
site/watch/
site/starmap/
site/founders/
site/collabs/

# scripts/print_report.sh 的 PDF 渲染中间产物 —— 每次跑就重生成,不入库
published/reports/*/report.print.html
# 旧 --inplace 之前会留下的 expanded.pdf 中间产物 —— 新版默认就地覆盖 report.pdf,不再有这文件
published/reports/*/report.expanded.pdf

# Cloudflare Wrangler 本地缓存
.wrangler/

# 增长辅助脚本运行日志 —— 每次运行就变,不入库
logs/

# 个人讲稿 / scratch 笔记(不入库)
demo-script-*.md

# 个人 Pitch 稿件(.docx)—— 黑客松 / 演讲稿,不入库
docs/hackathon/*.docx

# Python 字节码缓存(py_compile / pytest 等会生成)
__pycache__/
*.pyc

# pnpm workspace
node_modules/
packages/*/dist/
packages/*/coverage/
*.tsbuildinfo
